# ============================================================
# ZE-Ticket — Umgebungsvariablen Vorlage
# Kopieren: cp .env.example .env
# Dann alle Werte ausfüllen — niemals echte Werte committen!
# ============================================================

# === PostgreSQL ===
POSTGRES_DB=ze_ticket
POSTGRES_USER=ze_ticket_user
POSTGRES_PASSWORD=BITTE_AENDERN

# === Redis ===
REDIS_PASSWORD=BITTE_AENDERN

# === FastAPI ===
# Generieren mit: python3 -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=BITTE_AENDERN
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# === App ===
APP_ENV=production
APP_URL=https://deine-domain.de
APP_NAME=ZE-Ticket

# === Mail (SMTP) ===
SMTP_HOST=mail.deine-domain.de
SMTP_PORT=465
SMTP_USER=support@deine-domain.de
SMTP_PASSWORD=BITTE_AENDERN
SMTP_FROM=support@deine-domain.de
SMTP_FROM_NAME=ZE-Ticket Support
SMTP_SSL=true

# === IMAP (eingehende Mail) ===
IMAP_HOST=mail.deine-domain.de
IMAP_PORT=993
IMAP_USER=support@deine-domain.de
IMAP_PASSWORD=BITTE_AENDERN

# === Elasticsearch ===
ELASTIC_PASSWORD=BITTE_AENDERN

# === Zeitzone ===
TIMEZONE=Europe/Berlin
